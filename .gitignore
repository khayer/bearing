# BEARING .gitignore
#
# Goal: keep the repo to source, configs, and small reproducibility inputs.
# Everything a pipeline RUN produces is ignored.
#
# Deliberately NOT ignored (these belong in git):
#   *.py / *.sh / *.R analysis and helper scripts
#   workflow/Snakefile, workflow/config/config.yaml, workflow/config/samples*.tsv
#   workflow/profiles/, categories/, small annotation BEDs
#
# See the notes at the bottom before adding resources/ or annotations/.

# ---------------------------------------------------------------------------
# OS / editor noise
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
*.swp
*~
.idea/
.vscode/
\#*\#
.#*

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/
venv/
.venv/

# ---------------------------------------------------------------------------
# Snakemake / workflow run artifacts
# ---------------------------------------------------------------------------
.snakemake/
results/
workflow/results/
workflow/results_*/
results_*/

