docs/categories.json
docs/how_I_run_it.md

# ---------------------------------------------------------------------------
# Notes -- decide before submission, do NOT blanket-ignore:
#
# workflow/resources/    mm10.chrom.sizes, mm10-blacklist.v2.bed, the GENCODE
#                        GTF, mm10_genes.bed. Small files here are worth
#                        tracking; the GTF is large. Recommended: track the
#                        small ones, put the GTF behind a download script or
#                        the Zenodo archive, and reference it from config.yaml.
#
# annotations/           region BEDs live at the repo ROOT and are TRACKED (the
#                        duplicate workflow/annotations/ copy was removed).
# ---------------------------------------------------------------------------
workflow/resources/gencode.vM23.annotation_modified_overlaps_removed_sorted.gtf

# sync_manifest.sha256 is a build artifact (a regenerated checksum manifest),
# not a provenance record. Ignore it; untrack the committed copy once with:
#   git rm --cached sync_manifest.sha256
sync_manifest.sha256
