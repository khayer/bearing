# BEARING end-to-end workflow.
#
#   # local:
#   snakemake -s workflow/Snakefile --configfile workflow/config/config.yaml \
#             --cores 16 --use-apptainer
#   # cluster (Snakemake submits every rule to SLURM):
#   snakemake -s workflow/Snakefile --configfile workflow/config/config.yaml \
#             --profile workflow/profiles/slurm
#
# A single `snakemake` builds the whole DAG. Hi-C phases are requested only if
# the sample sheet defines Hi-C conditions (rows with a cool path), so the
# pipeline runs unchanged on BEARING data without any Hi-C inputs.
#
# Heavy multi-file steps (scoring, compare, perm nulls, p-values) use .done
# sentinels so Snakemake orders the phases without predicting every filename;
# downstream rules read the actual files, which exist once the sentinel is made.
# ASCII-only.

import os
import pandas as pd

configfile: "config/config.yaml"
container: config.get("container", "bearing.sif")

# Resolve config-relative paths against the workflow/ directory (where this
# Snakefile and config/ live), so the pipeline runs the same whether launched
# from the repo root or from workflow/. workflow.basedir is the Snakefile dir.
WFDIR = workflow.basedir
def wf(path):
    """Resolve a path that is written relative to workflow/ to an absolute path."""
    if os.path.isabs(path):
        return path
    return os.path.normpath(os.path.join(WFDIR, path))

BIN     = wf(config["bearing_dir"])
OUT     = wf(config["outdir"])
CATS    = wf(config["categories"])
CS      = wf(config["chrom_sizes"])
REGIONS = wf(config["regions_file"])
GENES   = wf(config["genes_bed"])
GTF     = wf(config.get("gtf", "")) if config.get("gtf", "") else ""
AGR     = wf(config.get("agr_genes_bed", "")) if config.get("agr_genes_bed", "") else ""
BL      = os.path.join(OUT, "blacklist", "merged_blacklist.bed")
P       = config  # parameters
SHEET   = wf(config["samples_sheet"])

def script(name):     return os.path.join(BIN, name)
def out(*parts):      return os.path.join(OUT, *parts)

# ---- parse sheet ----------------------------------------------------------
_sheet = pd.read_csv(SHEET, sep="\t", dtype=str,
                     comment="#").fillna("")
BEARING_ROWS = _sheet[_sheet["bw"].str.strip() != ""]
SAMPLES = BEARING_ROWS["sample"].tolist()
QCATS = [r["out"] for _, r in BEARING_ROWS.iterrows()]

# data_dir: what the sheet's relative bw paths resolve against (default cwd).
DATA_DIR = os.path.abspath(config.get("data_dir", "") or os.getcwd())
def _abs_bw_list(cell):
    paths = []
    for p in str(cell).split(","):
        p = p.strip()
        if not p:
            continue
        paths.append(p if os.path.isabs(p)
                     else os.path.normpath(os.path.join(DATA_DIR, p)))
    return paths
# per-sample maps for the per-sample score rule (10 parallel jobs)
SAMPLE_BW = {r["sample"]: _abs_bw_list(r["bw"])
             for _, r in BEARING_ROWS.iterrows()}
SAMPLE_OUT = {r["sample"]: r["out"] for _, r in BEARING_ROWS.iterrows()}

REF = config["reference_condition"]
CONDS = list(dict.fromkeys(BEARING_ROWS["condition"].tolist()))
COMPARISONS = ["%s_vs_%s" % (REF, c) for c in CONDS if c != REF]
PERM_INDICES = list(range(1, int(config["n_perms"]) + 1))

wildcard_constraints:
    idx=r"\d+",
    sample=r"[A-Za-z0-9_.-]+",
    cmp=r"[A-Za-z0-9_.-]+"

# Hi-C conditions: first row per condition with a cool path (dedup).
HIC = {}
for _, r in _sheet.iterrows():
    c = r["condition"]
    if r.get("cool", "").strip() and c not in HIC:
        HIC[c] = {"cool": r["cool"], "insul": r["insul"], "pca1": r["pca1"]}
HAS_HIC = len(HIC) > 0

def _abs_hic(p):
    """Resolve a Hi-C path (possibly relative like ../comp/...) to absolute
    against DATA_DIR, so it works regardless of a SLURM job's working dir."""
    if not p:
        return p
    return p if os.path.isabs(p) else os.path.normpath(os.path.join(DATA_DIR, p))

def hic_arg(field, res, conds=None):
    """Build 'COND=path COND=path ...' with {res} substituted, absolute paths."""
    conds = conds or list(HIC.keys())
    return " ".join("%s=%s" % (c, _abs_hic(HIC[c][field].replace("{res}", str(res))))
                    for c in conds if c in HIC)


# ---- targets --------------------------------------------------------------
def all_targets():
    t = [
        BL,
        out("score.done"),
        out("compare.done"),
        out("region_qc.done"),
        out("pvalue.done"),
        out("regional", "consolidated_enrichment.tsv"),
        out("regional", "panel_E_heatmap.pdf"),
        out("calibration.done"),
        out("decomposition.done"),
        out("benchmark", "recovery.done"),
        out("paper_figures", "graphical_abstract_panel3.png"),
        out("paper_figures", "fig6_panelB_igh_decomp.pdf"),
    ]
    if HAS_HIC:
        t += [out("figures.done"),
              out("hic", "tad.done"),
              out("hic", "compartment.done"),
              out("hic", "contact_isolation.done"),
              out("hic", "crosslocus.done"),
              out("paper_figures", "fig3_panelB_oe_grid.png"),
              out("paper_figures", "fig4_panelA_self_contact_grid.png"),
              out("paper_figures", "suppS7_panelB_compartment_res.png"),
              out("hic", "bes_hic_within.done")]
    return t

rule all:
    input: all_targets()


# ---- derive a BEARING-only sheet for the scoring/compare/perm tools -------
# (drops Hi-C-only rows and the Hi-C columns, which those tools do not need)
rule bearing_sheet:
    input: SHEET
    output:
        bw=out("samples.bearing.tsv"),
        qcat=out("samples.qcat.tsv")
    run:
        import os as _os
        # results/ may not exist yet on the first job; create it.
        _os.makedirs(_os.path.dirname(output.bw), exist_ok=True)
        # Resolve relative bw paths to ABSOLUTE. The score rule cd's into the
        # results dir, which would break paths like ../bigwigs/...; data_dir
        # (config, default = the launch directory) is what they are relative to.
        _data_dir = config.get("data_dir", "") or _os.getcwd()
        _data_dir = _os.path.abspath(_data_dir)
        def _abs_bw(cell):
            parts = []
            for p in str(cell).split(","):
                p = p.strip()
                if not p:
                    continue
                parts.append(p if _os.path.isabs(p)
                             else _os.path.normpath(_os.path.join(_data_dir, p)))
            return ",".join(parts)
        _bw = BEARING_ROWS[["sample", "condition", "replicate", "out", "bw"]].copy()
        _bw["bw"] = _bw["bw"].map(_abs_bw)
        _bw.to_csv(output.bw, sep="\t", index=False)
        # downstream sheet: absolute qcat paths so compare/perm find them
        # regardless of working directory (matches the score_sample outputs:
        # OUT/<sample>.qcat.bgz)
        q = BEARING_ROWS[["sample", "condition", "replicate"]].copy()
        q["qcat"] = [_os.path.join(OUT, "%s.qcat.bgz" % s)
                     for s in BEARING_ROWS["sample"]]
        q.to_csv(output.qcat, sep="\t", index=False)


# ---- Phase 0: blacklist ---------------------------------------------------
rule detect_blacklist:
    input: sheet=out("samples.bearing.tsv")
    output: out("blacklist", "detected_blacklist.bed")
    threads: 16
    resources: mem_mb=96000, runtime=1440, cpus_per_task=16
    shell:
        "python {BIN}/bigwig_to_qcat.py --sheet {input.sheet} --categories {CATS} "
        "--chrom-sizes {CS} "
        "--out {OUT}/blacklist/placeholder.qcat.bgz --detect-unmappable "
        "--unmappable-zero-frac 0.90 --unmappable-out {output} --jobs {threads}"

rule merge_blacklist:
    input: detected=out("blacklist", "detected_blacklist.bed")
    output: BL
    params: ext=config.get("blacklist_external", ""), d=P["blacklist_merge_distance"]
    shell:
        "cat {input.detected} | sort -k1,1 -k2,2n | bedtools merge -d {params.d} "
        "> {OUT}/blacklist/detected_merged.bed; "
        "cat {OUT}/blacklist/detected_merged.bed <(cut -f1-3 {params.ext}) "
        "| sort -k1,1 -k2,2n | bedtools merge > {output}"


# ---- Phase 1: observed scoring -- ONE SLURM JOB PER SAMPLE ----------------
# Each sample is scored independently, so all 10 run as parallel cluster jobs
# (10 jobs x 8 cores) instead of one serial job. bigwig_to_qcat parallelizes
# across chromosomes within a sample via --jobs. Outputs are written with
# absolute --out paths, so no cd is needed and input bw paths (absolute, built
# from data_dir) resolve regardless of working directory.
rule score_sample:
    input: blacklist=BL
    output: qcat=out("{sample}.qcat.bgz")
    params:
        bw=lambda wc: " ".join(SAMPLE_BW[wc.sample]),
        minsig=P["min_signal"], norm=P["normalize"]
    threads: 8
    resources: mem_mb=96000, runtime=720, cpus_per_task=8
    shell:
        "python {BIN}/bigwig_to_qcat.py --bw {params.bw} "
        "--sample-name {wildcards.sample} --out {output.qcat} "
        "--categories {CATS} --chrom-sizes {CS} --blacklist {input.blacklist} "
        "--min-signal {params.minsig} {params.norm} --jobs {threads} --signal-plots"

# Aggregator: depends on every per-sample qcat; downstream rules wait on this.
rule score:
    input: qcats=[out("%s.qcat.bgz" % s) for s in SAMPLES]
    output: done=touch(out("score.done"))


# ---- Phase 2: compare (all conditions, region set) ------------------------
rule compare:
    input: sheet=out("samples.qcat.tsv"), score=out("score.done"), regions=REGIONS
    output: done=touch(out("compare.done"))
    threads: 10
    resources: mem_mb=200000, runtime=1440, cpus_per_task=10
    shell:
        "python {BIN}/compare_qcat.py --sheet {input.sheet} --out {OUT}/compare "
        "--categories {CATS} --regions-file {input.regions} --genes {GENES} "
        "--no-clip --workers {threads}"

# ---- Phase 2b: per-region raw-signal QC PNGs (pyGenomeTracks) --------------
# One PNG per sample per region (raw BigWig tracks + BEARING score track), for
# eyeballing each locus. Output: results/raw_vs_bearing/<sample>_<region>.png
rule region_qc:
    input: sheet=out("samples.qcat.tsv"), score=out("score.done"), regions=REGIONS
    output: done=touch(out("region_qc.done"))
    resources: mem_mb=32000, runtime=240
    shell:
        "python {BIN}/batch_pygenometracks.py --sheet {input.sheet} "
        "--regions-file {input.regions} --outdir {OUT}/raw_vs_bearing "
        "--dpi 200 --skip-missing-ini --run"


# ---- Phase 3: permutation nulls -- ONE JOB PER (SAMPLE, PERMUTATION) -------
# The observed null for each (sample, permutation) is independent, so they run
# as separate cluster jobs: 10 samples x N perms. Each job shifts+scores ONE
# sample for ONE permutation (about the size of a score_sample job), avoiding
# the multi-hour serial scoring that hit the wall-clock limit. A per-index
# aggregator then waits for all samples before the differential step (which
# needs every condition present) runs for that permutation.
rule perm_sample_one:
    input: sheet=out("samples.bearing.tsv"), score=out("score.done"), blacklist=BL
    output: out("perm", "perm{idx}", "{sample}", "{sample}_perm{idx}.qcat.bgz")
    params: n=P["n_perms"], shift=P["min_shift"], seed=P["seed"], minsig=P["min_signal"]
    threads: 8
    resources: mem_mb=96000, runtime=720, cpus_per_task=8
    shell:
        "python {BIN}/generate_perm_nulls.py --sheet {input.sheet} --out-dir {OUT}/perm "
        "--chrom-sizes {CS} --n-perms {params.n} --perm-index {wildcards.idx} "
        "--only-sample {wildcards.sample} "
        "--blacklist {input.blacklist} --min-signal {params.minsig} "
        "--min-shift {params.shift} --seed {params.seed} "
        "--shift-workers {threads} --jobs {threads}"

# Per-index aggregator: all samples' observed nulls for this permutation exist.
rule perm_null_one:
    input: [out("perm", "perm{idx}", s, "%s_perm{idx}.qcat.bgz" % s) for s in SAMPLES]
    output: touch(out("perm", "perm{idx}.obs.done"))

rule perm_diff_one:
    input: obs=out("perm", "perm{idx}.obs.done"),
           sheet=out("samples.bearing.tsv"), blacklist=BL
    output: touch(out("perm", "perm{idx}.diff.done"))
    params: n=P["n_perms"]
    threads: 8
    resources: mem_mb=120000, runtime=720, cpus_per_task=8
    shell:
        "python {BIN}/generate_perm_nulls.py --sheet {input.sheet} --diff-sheet {input.sheet} "
        "--chrom-sizes {CS} --n-perms {params.n} --perm-index {wildcards.idx} "
        "--out-dir {OUT}/perm --blacklist {input.blacklist} --jobs {threads}"

# Aggregators: wait for all permutation rounds.
rule perm_nulls:
    input: [out("perm", "perm%d.obs.done" % i) for i in PERM_INDICES]
    output: touch(out("perm.done"))

rule perm_nulls_diff:
    input: [out("perm", "perm%d.diff.done" % i) for i in PERM_INDICES]
    output: touch(out("perm_diff.done"))


# ---- Phase 4: differential p-values (sbatch-free wrapper) -----------------
rule pvalue_diff:
    input: compare=out("compare.done"), perm_diff=out("perm_diff.done")
    output: done=touch(out("pvalue.done"))
    params: n=P["n_perms"]
    threads: 4
    resources: mem_mb=256000, runtime=1440, cpus_per_task=4
    shell:
        "export OMP_NUM_THREADS=1 MKL_NUM_THREADS=1 OPENBLAS_NUM_THREADS=1; "
        "bash {BIN}/slurm/run_perm_diff_pvalue.sh {OUT}/compare {params.n} {OUT}/perm/perm {OUT}/pvalue"


# ---- Phase 5: regional enrichment -----------------------------------------
rule regional_enrichment:
    input: pvalue=out("pvalue.done")
    output: out("regional", "enrich_{cmp}_tcrb_regions_v5.tsv")
    resources: mem_mb=100000, runtime=1440
    shell:
        "python {BIN}/regional_enrichment.py batch "
        "--diff-table {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--regions {BIN}/annotations/tcrb_regions_v5.bed --locus chr6:40790000-41690000 "
        "--out {output}"

rule regional_consolidate:
    input: expand(out("regional", "enrich_{cmp}_tcrb_regions_v5.tsv"), cmp=COMPARISONS)
    output: tsv=out("regional", "consolidated_enrichment.tsv"),
            pdf=out("regional", "panel_E_heatmap.pdf")
    shell:
        "python {BIN}/consolidate_regional_enrichment.py --tsvs {input} "
        "--out {output.tsv} --heatmap-out {output.pdf} "
        "--comparisons " + " ".join(COMPARISONS)


# ---- Phase 6: BEARING + Hi-C figures (Hi-C only) --------------------------
rule bearing_hic_figures:
    input: pvalue=out("pvalue.done"), regions=REGIONS
    output: done=touch(out("figures.done"))
    params:
        contacts=lambda wc: " ".join(
            "--contact %s=%s" % (c, _abs_hic(HIC[c]["cool"].replace("{res}", str(P["hic"]["contact_resolution"]))))
            for c in HIC if c in CONDS),
        res=P["hic"]["contact_resolution"]
    resources: mem_mb=100000, runtime=1440
    shell:
        "python {BIN}/batch_bearing_hic_plots.py --sheet {OUT}/samples.bearing.tsv "
        "--regions-file {input.regions} --reference-condition {REF} {params.contacts} "
        "--comparison-dir {OUT}/compare --gtf {GTF} --results-dir {OUT}/pvalue "
        "--outdir {OUT}/figures --no-pvals --triangle --run"


# ---- Phase 7: Hi-C analyses (Hi-C only) -----------------------------------
rule hic_tad_extension:
    output: done=touch(out("hic", "tad.done"))
    params:
        conds=" ".join(HIC.keys()), tad_dir=_abs_hic(P["hic"]["tad_dir"]),
        anchor=P["hic"]["tad_anchor"], feats=os.path.join(BIN, P["hic"]["features_bed"])
    resources: mem_mb=64000, runtime=720
    run:
        # Resolutions to plot; configurable via hic.tad_resolutions so the loop
        # only requests resolutions that actually exist on disk for the TAD
        # domain BEDs. A resolution with no loadable data logs a warning and is
        # skipped rather than aborting the whole rule. subprocess.run does NOT
        # expand Snakemake {placeholders}, so values are substituted explicitly.
        import subprocess as _sp
        _any = False
        for res in P["hic"].get("tad_resolutions", [100000, 25000, 250000, 500000]):
            cmd = (
                "python %s/hic/tad_extension_analysis.py --tad-dir %s "
                "--resolution %d --conditions %s --anchor %s "
                "--features-bed %s --out-prefix %s/hic/tcrb_tad_%d --plot"
                % (BIN, params.tad_dir, res, params.conds, params.anchor,
                   params.feats, OUT, res))
            if _sp.run(cmd, shell=True).returncode == 0:
                _any = True
            else:
                print("WARNING: TAD extension failed at resolution %d "
                      "(likely no domain BED present); continuing." % res)
        if not _any:
            raise RuntimeError("TAD extension produced no output at any "
                               "configured resolution; check hic.tad_resolutions "
                               "and the tad_dir contents.")

rule hic_compartment:
    output: done=touch(out("hic", "compartment.done"))
    params: region=P["hic"]["compartment_region"], tad_dir=_abs_hic(P["hic"]["tad_dir"]),
            feats=os.path.join(BIN, P["hic"]["features_bed"])
    resources: mem_mb=64000, runtime=720
    run:
        # Configurable via hic.compartment_resolutions; only request resolutions
        # whose pca1 BigWigs exist. A resolution with no loadable PC1 logs a
        # warning and is skipped rather than aborting the whole rule.
        # subprocess.run does NOT expand Snakemake {placeholders}, so values are
        # substituted explicitly.
        import subprocess as _sp
        _any = False
        for res in P["hic"].get("compartment_resolutions", [100000, 250000, 500000]):
            cmd = (
                "python %s/hic/compartment_analysis.py --pc1 %s --region %s "
                "--features-bed %s --tad-dir %s --tad-resolution %d "
                "--orient-with-gtf %s --out-prefix %s/hic/tcrb_compartment_%d"
                % (BIN, hic_arg("pca1", res), params.region, params.feats,
                   params.tad_dir, res, GTF, OUT, res))
            if _sp.run(cmd, shell=True).returncode == 0:
                _any = True
            else:
                print("WARNING: compartment analysis failed at resolution %d "
                      "(likely no pca1 BigWig present); continuing." % res)
        if not _any:
            raise RuntimeError("Compartment analysis produced no output at any "
                               "configured resolution; check "
                               "hic.compartment_resolutions and the comp/ contents.")

rule hic_contact_isolation:
    output: done=touch(out("hic", "contact_isolation.done"))
    params:
        cools=lambda wc: hic_arg("cool", P["hic"]["contact_resolution"]),
        target=P["hic"]["isolation_target"], win=P["hic"]["isolation_window"],
        maxd=P["hic"]["isolation_max_distance"], permn=P["hic"]["isolation_perm_n"]
    resources: mem_mb=100000, runtime=1440
    shell:
        "python {BIN}/hic/tcrb_contact_isolation.py --cool {params.cools} --target {params.target} "
        "--window-size {params.win} --max-distance {params.maxd} --perm-n {params.permn} "
        "--out-prefix {OUT}/hic/tcrb_isolation_OE_perm"

rule hic_crosslocus:
    input: pvalue=out("pvalue.done"), blacklist=BL
    output: done=touch(out("hic", "crosslocus.done"))
    params:
        res=P["hic"]["contact_resolution"],
        targets=os.path.join(BIN, P["hic"]["crosslocus_targets"])
    resources: mem_mb=100000, runtime=1440
    run:
        res = params.res
        diffs = " ".join("%s_vs_%s=%s/pvalue/diff_%s.stats.tsv" % (REF, c, OUT, "%s_vs_%s" % (REF, c))
                         for c in HIC if c in CONDS and c != REF)
        cool_a = _abs_hic(HIC[REF]["cool"].replace("{res}", str(res)))
        cool_b = " ".join("%s_vs_%s=%s" % (REF, c, _abs_hic(HIC[c]["cool"].replace("{res}", str(res))))
                          for c in HIC if c in CONDS and c != REF)
        ires = P["hic"].get("insulation_resolution", 25000)
        insul_a = _abs_hic(HIC[REF]["insul"].replace("{res}", str(ires)))
        insul_b = " ".join("%s_vs_%s=%s" % (REF, c, _abs_hic(HIC[c]["insul"].replace("{res}", str(ires))))
                           for c in HIC if c in CONDS and c != REF)
        shell("python {BIN}/hic/bes_hic_crosslocus.py --diffs %s --cool-a %s --cool-b %s "
              "--insul-a %s --insul-b %s "
              "--targets {params.targets} --hic-bin %d --aggregation p95 "
              "--contact-metric delta_contact --n-controls 200 --n-panels 1000 "
              "--blacklist {input.blacklist} --gtf {GTF} --match-gene-density "
              "--out-prefix {OUT}/hic/crosslocus_p95_dcontact"
              % (diffs, cool_a, cool_b, insul_a, insul_b, res))


# ---- Phase 8-10: calibration, decomposition, synthetic benchmark ----------
rule calibration_one:
    # Per-condition replicate calibration; one SLURM job per condition so the
    # five conditions run in parallel instead of serially in a single job. Each
    # job writes to its own out dir so the script's per-run summary table does
    # not collide/race across the parallel jobs.
    input: score=out("score.done")
    output: summary=out("calibration", "{cond}", "{cond}", "{cond}_summary.txt")
    params: nperms=P.get("n_perms", 10), outdir=lambda wc: out("calibration", wc.cond)
    resources: mem_mb=200000, runtime=1440
    shell:
        "bash {BIN}/run_replicate_calibration.sh "
        "--sheet {OUT}/samples.qcat.tsv --out {params.outdir} "
        "--perm-template '{OUT}/perm/perm{{perm}}/{{sample}}/{{sample}}_perm{{perm}}.qcat.bgz' "
        "--n-perms {params.nperms} --obs-qcat-col qcat --scripts-dir {BIN} "
        "--conditions {wildcards.cond}"

rule calibration:
    # Aggregate the per-condition summaries into one combined table. Built fresh
    # here (rather than relying on the script's in-loop append) because the
    # per-condition jobs run concurrently in isolated out dirs.
    input: summaries=expand(out("calibration", "{cond}", "{cond}", "{cond}_summary.txt"), cond=CONDS)
    output: done=touch(out("calibration.done")),
            table=out("calibration", "calibration_summary.tsv")
    run:
        import re as _re
        import os as _os
        with open(output.table, "w") as _o:
            _o.write("condition\tn_bins\tlambda\tpct_at_floor\t"
                     "bh_significant\tverdict\n")
            for _s in input.summaries:
                _cond = _os.path.basename(_s).replace("_summary.txt", "")
                _txt = open(_s).read()
                def _grab(pat, default="NA"):
                    m = _re.search(pat, _txt, _re.M)
                    return m.group(1).strip() if m else default
                _nbins = _grab(r"^observed bins \(n\)\s*:\s*([\d,]+)")
                _lam = _grab(r"^genomic-inflation lam\s*:\s*([\d.]+)")
                _floor = _grab(r"^bins at floor\s*:.*\(([\d.]+)%\)")
                _bh = _grab(r"^BH-significant.*:\s*([\d,]+)")
                _verdict = _grab(r"^VERDICT:\s*([A-Z]+)")
                _o.write("\t".join([_cond, _nbins, _lam, _floor,
                                    _bh, _verdict]) + "\n")

rule decomposition_report:
    input: pvalue=out("pvalue.done")
    output: done=touch(out("decomposition.done"))
    resources: mem_mb=64000, runtime=240
    shell:
        "python {BIN}/bearing_decomposition_report.py --diff-dir {OUT}/pvalue "
        "--categories {OUT}/DN_rep1_cats.json --out {OUT}/cross_comparison --top-n 500"

rule benchmark:
    output: done=touch(out("benchmark", "recovery.done"))
    params: pfx=out("benchmark", "sim"), outdir=out("benchmark", "recovery")
    resources: mem_mb=32000, runtime=720
    shell:
        "python {BIN}/benchmark/simulate_bearing_tracks.py --prefix {params.pfx} --seed 1; "
        "python {BIN}/benchmark/evaluate_bearing_recovery.py "
        "--truth {params.pfx}_truth.tsv "
        "--bw {params.pfx}_atac.bw {params.pfx}_rnaplus.bw {params.pfx}_rnaminus.bw "
        "{params.pfx}_ctcf.bw {params.pfx}_rad21.bw {params.pfx}_h3k27ac.bw "
        "--chrom-sizes {params.pfx}.chrom.sizes --scorer {BIN}/bigwig_to_qcat.py "
        "--outdir {params.outdir}"


# ---- Paper-figure grid wrappers (Hi-C only) -------------------------------
# Composite panels that no single analysis script emits as one call. Reuse the
# .cool / pca1 inputs already in the sheet. Two cell-type sets are used:
# all five for the main O/E grids, the V1-perturbation pair is handled by the
# existing hic_contact_isolation rule (Supp S7A).
LYMPH5 = [c for c in ["DN", "DP", "EbKO", "ProB", "S3T3"] if c in HIC]

rule fig3b_oe_grid:
    output: out("paper_figures", "fig3_panelB_oe_grid.png")
    params:
        cools=lambda wc: " ".join(
            "%s=%s" % (c, _abs_hic(HIC[c]["cool"].replace("{res}", "25000"))) for c in LYMPH5)
    resources: mem_mb=32000, runtime=240
    shell:
        "python {BIN}/paper/figures/oe_contact_grid.py --cool {params.cools} "
        "--region chr6:40400000-42400000 --resolution 25000 --vmin -2 --vmax 2 "
        "--ncols 5 --annotate-oe-region chr6:41000000-41600000 --out {output}"

rule fig4a_self_contact_grid:
    output: out("paper_figures", "fig4_panelA_self_contact_grid.png")
    params:
        cools=lambda wc: " ".join(
            "%s=%s" % (c, _abs_hic(HIC[c]["cool"].replace("{res}", "25000"))) for c in LYMPH5)
    resources: mem_mb=32000, runtime=240
    shell:
        "python {BIN}/paper/figures/oe_contact_grid.py --cool {params.cools} "
        "--region chr6:39900000-42900000 --resolution 25000 --vmin -2 --vmax 2 "
        "--ncols 5 --annotate-oe-region chr6:40400000-42400000 --out {output}"

rule suppS7b_compartment_grid:
    output: out("paper_figures", "suppS7_panelB_compartment_res.png")
    params:
        pc1=lambda wc: " ".join(
            "%s=%s" % (c, _abs_hic(HIC[c]["pca1"])) for c in LYMPH5)  # path keeps {res}
    resources: mem_mb=32000, runtime=240
    shell:
        "python {BIN}/paper/figures/compartment_resolution_grid.py --pc1 {params.pc1} "
        "--resolutions 25000 50000 100000 --region chr6:39000000-43500000 "
        "--landmarks Cntnap2:chr6:46400000:B Gpnmb:chr6:48900000:A Tcrb:chr6:41000000:A "
        "--out {output}"


# ---- Additional manuscript-figure rules -----------------------------------
# Graphical-abstract panel 3 (diffuse architecture / focal transcription) and
# the Fig 6B Igh per-track decomposition are independent figure scripts that
# were not previously emitted by any rule.

rule graphical_abstract_panel3:
    input: pvalue=out("pvalue.done")
    output: out("paper_figures", "graphical_abstract_panel3.png")
    params:
        diff=lambda wc: out("pvalue", "diff_%s_vs_ProB.stats.tsv" % REF)
    resources: mem_mb=16000, runtime=120
    shell:
        "python {BIN}/diffuse_architecture_top1pct.py "
        "--diff {params.diff} --region chr6:40400000-42400000 "
        "--focal chr6:41450000-41600000 --window 10 --pct 1 "
        "--figure {output} --out-prefix {OUT}/paper_figures/ga_panel3"

rule fig6b_igh_decomp:
    input: pvalue=out("pvalue.done")
    output: out("paper_figures", "fig6_panelB_igh_decomp.pdf")
    params: prefix=out("paper_figures", "fig6_panelB_igh_decomp")
    resources: mem_mb=16000, runtime=120
    shell:
        "python {BIN}/bearing_region_decomposition.py "
        "--diff-dir {OUT}/pvalue --regions {BIN}/annotations/igh_regions_v4.bed "
        "--categories {OUT}/DN_rep1_cats.json "
        "--filename-pattern 'diff_*.stats.tsv' "
        "--out {params.prefix}"

# S7C: within-Tcrb BES-Hi-C co-localization (distinct from the pooled
# cross-locus hic/bes_hic_crosslocus.py already wired in hic_crosslocus).
rule bes_hic_within:
    input: pvalue=out("pvalue.done")
    output: done=touch(out("hic", "bes_hic_within.done"))
    params:
        res=P["hic"]["contact_resolution"],
        cool_a=lambda wc: _abs_hic(HIC[REF]["cool"].replace("{res}", str(P["hic"]["contact_resolution"]))) if REF in HIC else "",
        cool_b=lambda wc: _abs_hic(HIC["DP"]["cool"].replace("{res}", str(P["hic"]["contact_resolution"]))) if "DP" in HIC else "",
        insul_a=lambda wc: _abs_hic(HIC[REF]["insul"].replace("{res}", str(P["hic"].get("insulation_resolution", 25000)))) if REF in HIC else "",
        insul_b=lambda wc: _abs_hic(HIC["DP"]["insul"].replace("{res}", str(P["hic"].get("insulation_resolution", 25000)))) if "DP" in HIC else ""
    resources: mem_mb=64000, runtime=720
    shell:
        "python {BIN}/bes_hic_correlation.py "
        "--bes {OUT}/pvalue/diff_{REF}_vs_DP.stats.tsv "
        "--insul-A {params.insul_a} --insul-B {params.insul_b} "
        "--cool-A {params.cool_a} --cool-B {params.cool_b} "
        "--region chr6:40400000-42400000 --hic-bin {params.res} "
        "--n-perm 1000 --prefix {OUT}/hic/bes_hic_within_DN_vs_DP"
