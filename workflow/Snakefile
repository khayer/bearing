# ---- Consensus-Q diagnostic chain (isolated; does NOT touch canonical results)
# Re-scores against an element-wise-median consensus Q to test whether the
# genome-wide CTCF/Cohesin-dominated DN-vs-EbKO shift seen in the cross-locus
# survey collapses under a comparability-robust Q. All outputs live under
# results/consensusQ/ so the canonical compare/pvalue results are untouched.
rule compare_consensusq:
    input: sheet=out("samples.qcat.tsv"), score=out("score.done"), regions=REGIONS
    output: done=touch(out("consensusQ", "compare.done"))
    threads: 10
    resources: mem_mb=200000, runtime=1440, cpus_per_task=10
    shell:
        "python {BIN}/compare_qcat.py --sheet {input.sheet} "
        "--out {OUT}/consensusQ/compare "
        "--categories {CATS} --regions-file {input.regions} --genes {GENES} "
        "--no-clip --workers {threads} --consensus-q"

rule pvalue_consensusq:
    input: compare=out("consensusQ", "compare.done"), perm_diff=out("perm_diff.done")
    output: done=touch(out("consensusQ", "pvalue.done"))
    params: n=P["n_perms"]
    threads: 4
    resources: mem_mb=256000, runtime=1440, cpus_per_task=4
    shell:
        "export OMP_NUM_THREADS=1 MKL_NUM_THREADS=1 OPENBLAS_NUM_THREADS=1; "
        "bash {BIN}/slurm/run_perm_diff_pvalue.sh {OUT}/consensusQ/compare {params.n} "
        "{OUT}/perm/perm {OUT}/consensusQ/pvalue"

