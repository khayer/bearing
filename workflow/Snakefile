# Combined Hi-C + BEARING browser figures (bearing_hic_combined_plot.py, a
# drop-in for the triangle plotter). Same contacts/loops/p-values/RGB; written
# to figures/combined so the two figure styles sit in sibling folders.
# Combined Hi-C + BEARING browser figures (bearing_hic_combined_plot.py).
# Calls the combined plotter DIRECTLY per comparison (REF vs each cond) -- the
# batch runner cannot express its distinctive options (--show-hic A,B,diff,
# --insul-A/-B insulation tracks, --diff-stats). Produces the stacked layout:
# Hi-C A / Hi-C B / Hi-C diff triangles, insulation A vs B, |delta insul|, BES,
# diff p-value, per-track KL decomposition. Written to figures/combined/.
rule bearing_hic_combined_one:
    input: pvalue=out("pvalue.done"), psample=out("pvalue_samples.done"), regions=REGIONS
    output: out("figures", "combined", "{cmp}", "combined.done")
    wildcard_constraints: cmp=r"[A-Za-z0-9]+_vs_[A-Za-z0-9]+"
    params:
        cond=lambda wc: wc.cmp.split("_vs_")[-1],
        subdir=lambda wc: out("figures", "combined", wc.cmp),
        cool_a=lambda wc: _abs_hic(HIC[REF]["cool"].replace("{res}", str(P["hic"]["contact_resolution"]))),
        cool_b=lambda wc: _abs_hic(HIC[wc.cmp.split("_vs_")[-1]]["cool"].replace("{res}", str(P["hic"]["contact_resolution"]))),
        insul_a=lambda wc: _abs_hic(HIC[REF]["insul"].replace("{res}", str(P["hic"].get("insulation_resolution", 25000)))),
        insul_b=lambda wc: _abs_hic(HIC[wc.cmp.split("_vs_")[-1]]["insul"].replace("{res}", str(P["hic"].get("insulation_resolution", 25000)))),
        loops_a=lambda wc: ("--loops-a %s" % _abs_hic(HIC[REF]["loops"])) if HIC.get(REF, {}).get("loops") else "",
        loops_b=lambda wc: ("--loops-b %s" % _abs_hic(HIC[wc.cmp.split("_vs_")[-1]]["loops"])) if HIC.get(wc.cmp.split("_vs_")[-1], {}).get("loops") else "",
        res=P["hic"]["contact_resolution"]
    resources: mem_mb=100000, runtime=1440
    shell:
        "python {BIN}/bearing_hic_combined_plot.py "
        "--contact-a {params.cool_a} --contact-b {params.cool_b} "
        "--qcat-a {OUT}/{REF}_rep1.qcat.bgz --qcat-b {OUT}/{params.cond}_rep1.qcat.bgz "
        "--diff-qcat {OUT}/compare/diff_{wildcards.cmp}.qcat.bgz "
        "--diff-stats {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--pval-diff {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--insul-A {params.insul_a} --insul-B {params.insul_b} "
        "{params.loops_a} {params.loops_b} "
        "--show-hic A,B,diff --resolution {params.res} "
        "--regions-file {input.regions} --gtf {GTF} "
        "--categories {OUT}/DN_rep1_cats.json "
        "--bed {AGR} --bed {CBE} "
        "--label-a {REF} --label-b {params.cond} "
        "--outdir {params.subdir}; "
        # only mark done if PDFs were produced in this comparison's subfolder
        "if [ -n \"$(find {params.subdir} -name '*.pdf' -print -quit 2>/dev/null)\" ]; then "
        "touch {output}; "
        "else echo 'ERROR: combined plot produced no PDFs in {params.subdir}' >&2; exit 1; fi"

rule bearing_hic_combined_figures:
    input: [out("figures", "combined", "%s" % c, "combined.done") for c in COMPARISONS]
