        "--pvalue-dir {OUT}/pvalue --regions {input.regions} "
        "--mode diff --fdr {params.fdr} --out {output.tsv}"

# ---- Loop topology (#2 anchor-stratified BES, #3 differential loops) -------
# B-condition of comparison REF_vs_<c> is <c>. #2 needs <c>'s loops; #3 needs
# both REF and <c> loops. These run only over comparisons whose required loop
# files exist (HIC[...]["loops"] non-empty), so they no-op cleanly until loop
# BEDPEs are filled in for more conditions.
def _cond_of(cmp):           # REF_vs_<c> -> <c>
    return cmp.split("_vs_")[-1]

def _anchor_cmps():          # comparisons whose B-condition has loops
    return [c for c in COMPARISONS
            if HIC.get(_cond_of(c), {}).get("loops")]

def _diffloop_cmps():        # comparisons where BOTH REF and B have loops
    return [c for c in COMPARISONS
            if HIC.get(REF, {}).get("loops") and HIC.get(_cond_of(c), {}).get("loops")]

rule bes_loop_anchor:
    input: pvalue=out("pvalue.done")
    output: out("loops", "anchor_enrichment_{cmp}.tsv")
    wildcard_constraints: cmp=r"[A-Za-z0-9]+_vs_[A-Za-z0-9]+"
    resources: mem_mb=32000, runtime=120
    params:
        loops=lambda wc: _abs_hic(HIC[_cond_of(wc.cmp)]["loops"])
    shell:
        "python {BIN}/bes_loop_anchor_enrichment.py "
        "--diff {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--loops {params.loops} --categories {OUT}/DN_rep1_cats.json --out {output}"

rule bes_differential_loops:
    input: pvalue=out("pvalue.done")
    output: out("loops", "differential_loops_{cmp}.tsv")
    wildcard_constraints: cmp=r"[A-Za-z0-9]+_vs_[A-Za-z0-9]+"
    resources: mem_mb=32000, runtime=120
    params:
        loops_a=lambda wc: _abs_hic(HIC[REF]["loops"]),
        loops_b=lambda wc: _abs_hic(HIC[_cond_of(wc.cmp)]["loops"])
    shell:
        "python {BIN}/bes_differential_loops.py "
        "--loops-a {params.loops_a} --loops-b {params.loops_b} "
        "--diff {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--categories {OUT}/DN_rep1_cats.json --out {output}"

# Locus-scoped versions (default = Tcrb window via config 'loops_locus'). The
# genome-wide versions are dominated by the noise floor; these re-ask the
# topology question within the locus where real signal lives.
LOOPS_LOCUS = config.get("loops_locus", "chr6:40790000-41690000")

rule bes_loop_anchor_locus:
    input: pvalue=out("pvalue.done")
    output: out("loops", "anchor_enrichment_{cmp}_tcrb.tsv")
    resources: mem_mb=32000, runtime=120
    params:
        loops=lambda wc: _abs_hic(HIC[_cond_of(wc.cmp)]["loops"])
    shell:
        "python {BIN}/bes_loop_anchor_enrichment.py "
        "--diff {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--loops {params.loops} --categories {OUT}/DN_rep1_cats.json "
        "--locus %s --out {output}" % LOOPS_LOCUS

rule bes_differential_loops_locus:
    input: pvalue=out("pvalue.done")
    output: out("loops", "differential_loops_{cmp}_tcrb.tsv")
    resources: mem_mb=32000, runtime=120
    params:
        loops_a=lambda wc: _abs_hic(HIC[REF]["loops"]),
        loops_b=lambda wc: _abs_hic(HIC[_cond_of(wc.cmp)]["loops"])
    shell:
        "python {BIN}/bes_differential_loops.py "
        "--loops-a {params.loops_a} --loops-b {params.loops_b} "
        "--diff {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--categories {OUT}/DN_rep1_cats.json "
        "--locus %s --out {output}" % LOOPS_LOCUS

rule loops_topology:
    input:
        anchor=expand(out("loops", "anchor_enrichment_{cmp}.tsv"), cmp=_anchor_cmps()),
        diff=expand(out("loops", "differential_loops_{cmp}.tsv"), cmp=_diffloop_cmps()),
        anchor_tcrb=expand(out("loops", "anchor_enrichment_{cmp}_tcrb.tsv"), cmp=_anchor_cmps()),
        diff_tcrb=expand(out("loops", "differential_loops_{cmp}_tcrb.tsv"), cmp=_diffloop_cmps())
    output: done=touch(out("loops", "topology.done"))


