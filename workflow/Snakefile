# Per-region, per-comparison FDR-significant bin counts from the differential
# p-value tables (diff_<cmp>.stats.tsv). Stands alone from the (parallelized)
# figure jobs that previously produced this as a side effect.
rule significant_bins_summary:
    input: pvalue=out("pvalue.done"), regions=REGIONS
    output: tsv=out("regional", "significant_bins_summary.tsv")
