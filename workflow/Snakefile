    params:
        cond=lambda wc: wc.cmp.split("_vs_")[-1],
        subdir=lambda wc: out("figures", "triangle", wc.cmp),
        cool_a=lambda wc: _abs_hic(HIC[REF]["cool"].replace("{res}", str(P["hic"]["contact_resolution"]))),
        cool_b=lambda wc: _abs_hic(HIC[wc.cmp.split("_vs_")[-1]]["cool"].replace("{res}", str(P["hic"]["contact_resolution"]))),
        loops_a=lambda wc: ("--loops-a %s" % _abs_hic(HIC[REF]["loops"])) if HIC.get(REF, {}).get("loops") else "",
        loops_b=lambda wc: ("--loops-b %s" % _abs_hic(HIC[wc.cmp.split("_vs_")[-1]]["loops"])) if HIC.get(wc.cmp.split("_vs_")[-1], {}).get("loops") else "",
        res=P["hic"]["contact_resolution"]
    resources: mem_mb=100000, runtime=1440
    shell:
