# BEARING end-to-end workflow.
#
#   # local:
#   snakemake -s workflow/Snakefile --configfile workflow/config/config.yaml \
#             --cores 16 --use-apptainer
#   # cluster (Snakemake submits every rule to SLURM):
#   snakemake -s workflow/Snakefile --configfile workflow/config/config.yaml \
#             --profile workflow/profiles/slurm
#
# A single `snakemake` builds the whole DAG. Hi-C phases are requested only if
# the sample sheet defines Hi-C conditions (rows with a cool path), so the
# pipeline runs unchanged on BEARING data without any Hi-C inputs.
#
# Heavy multi-file steps (scoring, compare, perm nulls, p-values) use .done
# sentinels so Snakemake orders the phases without predicting every filename;
# downstream rules read the actual files, which exist once the sentinel is made.
# ASCII-only.

import os
import pandas as pd

configfile: "config/config.yaml"
container: config.get("container", "bearing.sif")

# Resolve config-relative paths against the workflow/ directory (where this
# Snakefile and config/ live), so the pipeline runs the same whether launched
# from the repo root or from workflow/. workflow.basedir is the Snakefile dir.
WFDIR = workflow.basedir
def wf(path):
    """Resolve a path that is written relative to workflow/ to an absolute path."""
    if os.path.isabs(path):
        return path
    return os.path.normpath(os.path.join(WFDIR, path))

BIN     = wf(config["bearing_dir"])
OUT     = wf(config["outdir"])
CATS    = wf(config["categories"])
CS      = wf(config["chrom_sizes"])
REGIONS = wf(config["regions_file"])
GENES   = wf(config["genes_bed"])
GTF     = wf(config.get("gtf", "")) if config.get("gtf", "") else ""
# annotation beds live under the bearing dir (BIN), like cbe_point_query's
# {BIN}/annotations/cbe_mm10.bed -- resolve relative to BIN, not workflow/.
AGR     = os.path.normpath(os.path.join(BIN, config.get("agr_genes_bed", "annotations/AgRgenes_mm10_s.bed")))
CBE     = os.path.normpath(os.path.join(BIN, config.get("cbe_bed", "annotations/cbe_mm10.bed")))
BL      = os.path.join(OUT, "blacklist", "merged_blacklist.bed")
P       = config  # parameters
SHEET   = wf(config["samples_sheet"])

def script(name):     return os.path.join(BIN, name)
def out(*parts):      return os.path.join(OUT, *parts)

# ---- parse sheet ----------------------------------------------------------
_sheet = pd.read_csv(SHEET, sep="\t", dtype=str,
                     comment="#").fillna("")
BEARING_ROWS = _sheet[_sheet["bw"].str.strip() != ""]
SAMPLES = BEARING_ROWS["sample"].tolist()
QCATS = [r["out"] for _, r in BEARING_ROWS.iterrows()]

# data_dir: what the sheet's relative bw paths resolve against (default cwd).
DATA_DIR = os.path.abspath(config.get("data_dir", "") or os.getcwd())
def _abs_bw_list(cell):
    paths = []
    for p in str(cell).split(","):
        p = p.strip()
        if not p:
            continue
        paths.append(p if os.path.isabs(p)
                     else os.path.normpath(os.path.join(DATA_DIR, p)))
    return paths
# per-sample maps for the per-sample score rule (10 parallel jobs)
SAMPLE_BW = {r["sample"]: _abs_bw_list(r["bw"])
             for _, r in BEARING_ROWS.iterrows()}
SAMPLE_OUT = {r["sample"]: r["out"] for _, r in BEARING_ROWS.iterrows()}

REF = config["reference_condition"]
CONDS = list(dict.fromkeys(BEARING_ROWS["condition"].tolist()))
COMPARISONS = ["%s_vs_%s" % (REF, c) for c in CONDS if c != REF]

# Regional-enrichment loci (Methods M.7): one jointly BH-corrected test family
# per locus (regions x comparisons), using the recalibrated one-sided
# directional test against a per-comparison genome-wide baseline g_dir.
REGIONAL_LOCI = config.get("regional_loci", {
    "tcrb": {"bed": "annotations/tcrb_regions_v5.bed", "window": "chr6:40790000-41690000"},
    "igh":  {"bed": "annotations/igh_regions_v4.bed",  "window": "chr12:113000000-116100000"},
})
REGIONAL_PTHRESH = config.get("regional_p_thresh", 0.05)
REGIONAL_LOCUS_RE = "|".join(REGIONAL_LOCI.keys())
REGIONAL_CMP_RE = "|".join(COMPARISONS)

# All pairwise comparisons, named exactly as compare_qcat.py emits them:
# combinations(sorted(conditions), 2) -> diff_<A>_vs_<B>. COMPARISONS above is
# only REF-vs-rest; the differential p-value step covers every pair, so the
# per-comparison pvalue rule keys on this full list (e.g. EbKO_vs_ProB).
from itertools import combinations as _combinations
ALL_PAIRWISE = ["%s_vs_%s" % (a, b)
                for a, b in _combinations(sorted(CONDS), 2)]
ALL_PAIRWISE_RE = "|".join(ALL_PAIRWISE)

PERM_INDICES = list(range(1, int(config["n_perms"]) + 1))

wildcard_constraints:
    idx=r"\d+",
    sample=r"[A-Za-z0-9_.-]+",
    cmp=r"[A-Za-z0-9_.-]+"

# Hi-C conditions: first row per condition with a cool path (dedup).
HIC = {}
for _, r in _sheet.iterrows():
    c = r["condition"]
    if r.get("cool", "").strip() and c not in HIC:
        HIC[c] = {"cool": r["cool"], "insul": r["insul"], "pca1": r["pca1"],
                  "loops": r.get("loops", "").strip()}
HAS_HIC = len(HIC) > 0

def _abs_hic(p):
    """Resolve a Hi-C path (possibly relative like ../comp/...) to absolute
    against DATA_DIR, so it works regardless of a SLURM job's working dir."""
    if not p:
        return p
    return p if os.path.isabs(p) else os.path.normpath(os.path.join(DATA_DIR, p))

def hic_arg(field, res, conds=None):
    """Build 'COND=path COND=path ...' with {res} substituted, absolute paths."""
    conds = conds or list(HIC.keys())
    return " ".join("%s=%s" % (c, _abs_hic(HIC[c][field].replace("{res}", str(res))))
                    for c in conds if c in HIC)


# ---- targets --------------------------------------------------------------
def all_targets():
    t = [
        BL,
        out("score.done"),
        out("compare.done"),
        out("region_qc.done"),
        out("pvalue.done"),
        *expand(out("regional", "consolidated_enrichment_{locus}.tsv"),
                locus=list(REGIONAL_LOCI.keys())),
        out("regional", "cbe_point_query.tsv"),
        out("regional", "cbe_track_changes.tsv"),
        out("regional", "agr_track_changes.tsv"),
        out("regional", "significant_bins_summary.tsv"),
        out("loops", "topology.done"),
        *expand(out("regional", "panel_E_heatmap_{locus}.pdf"),
                locus=list(REGIONAL_LOCI.keys())),
        out("calibration.done"),
        out("decomposition.done"),
        out("benchmark", "recovery.done"),
    ]
    # Manuscript paper figures assume the manuscript conditions (ProB, EbKO, Igh).
    # Skip them for application configs (e.g. the V1 panel) via paper_figures: false.
    if config.get("paper_figures", True):
        t += [
            out("paper_figures", "graphical_abstract_panel3.png"),
            out("paper_figures", "fig6_panelB_igh_decomp.pdf"),
            out("paper_figures", "suppS1_jsd_decomposition.pdf"),
            out("paper_figures", "qc_crosslocus_ebko_survey_rawQ.pdf"),
            out("paper_figures", "collect.done"),
        ]
    if HAS_HIC:
        t += [out("figures.done"),
              out("figures_combined.done"),
              out("pvalue_samples.done"),
              out("hic", "tad.done"),
              out("hic", "compartment.done"),
              out("hic", "contact_isolation.done"),
              out("hic", "crosslocus.done"),
              out("paper_figures", "fig3_panelB_oe_grid.png"),
              out("paper_figures", "fig4_panelA_self_contact_grid.png"),
              out("paper_figures", "suppS7_panelB_compartment_res.png"),
              out("hic", "bes_hic_within.done")]
    return t

rule all:
    input: all_targets()


# ---- derive a BEARING-only sheet for the scoring/compare/perm tools -------
# (drops Hi-C-only rows and the Hi-C columns, which those tools do not need)
rule bearing_sheet:
    input: SHEET
    output:
        bw=out("samples.bearing.tsv"),
        qcat=out("samples.qcat.tsv")
    run:
        import os as _os
        # results/ may not exist yet on the first job; create it.
        _os.makedirs(_os.path.dirname(output.bw), exist_ok=True)
        # Resolve relative bw paths to ABSOLUTE. The score rule cd's into the
        # results dir, which would break paths like ../bigwigs/...; data_dir
        # (config, default = the launch directory) is what they are relative to.
        _data_dir = config.get("data_dir", "") or _os.getcwd()
        _data_dir = _os.path.abspath(_data_dir)
        def _abs_bw(cell):
            parts = []
            for p in str(cell).split(","):
                p = p.strip()
                if not p:
                    continue
                parts.append(p if _os.path.isabs(p)
                             else _os.path.normpath(_os.path.join(_data_dir, p)))
            return ",".join(parts)
        _bw = BEARING_ROWS[["sample", "condition", "replicate", "out", "bw"]].copy()
        _bw["bw"] = _bw["bw"].map(_abs_bw)
        _bw.to_csv(output.bw, sep="\t", index=False)
        # downstream sheet: absolute qcat paths so compare/perm find them
        # regardless of working directory (matches the score_sample outputs:
        # OUT/<sample>.qcat.bgz)
        q = BEARING_ROWS[["sample", "condition", "replicate"]].copy()
        q["qcat"] = [_os.path.join(OUT, "%s.qcat.bgz" % s)
                     for s in BEARING_ROWS["sample"]]
        q.to_csv(output.qcat, sep="\t", index=False)


# ---- Phase 0: blacklist ---------------------------------------------------
rule detect_blacklist:
    input: sheet=out("samples.bearing.tsv")
    output: out("blacklist", "detected_blacklist.bed")
    threads: 16
    resources: mem_mb=96000, runtime=1440, cpus_per_task=16
    shell:
        "python {BIN}/bigwig_to_qcat.py --sheet {input.sheet} --categories {CATS} "
        "--chrom-sizes {CS} "
        "--out {OUT}/blacklist/placeholder.qcat.bgz --detect-unmappable "
        "--unmappable-zero-frac 0.90 --unmappable-out {output} --jobs {threads}"

rule merge_blacklist:
    input: detected=out("blacklist", "detected_blacklist.bed")
    output: BL
    params: ext=config.get("blacklist_external", ""), d=P["blacklist_merge_distance"]
    shell:
        "cat {input.detected} | sort -k1,1 -k2,2n | bedtools merge -d {params.d} "
        "> {OUT}/blacklist/detected_merged.bed; "
        "cat {OUT}/blacklist/detected_merged.bed <(cut -f1-3 {params.ext}) "
        "| sort -k1,1 -k2,2n | bedtools merge > {output}"


# ---- Phase 1: observed scoring -- ONE SLURM JOB PER SAMPLE ----------------
# Each sample is scored independently, so all 10 run as parallel cluster jobs
# (10 jobs x 8 cores) instead of one serial job. bigwig_to_qcat parallelizes
# across chromosomes within a sample via --jobs. Outputs are written with
# absolute --out paths, so no cd is needed and input bw paths (absolute, built
# from data_dir) resolve regardless of working directory.
# ---- optional cohort-wide per-track normalization reference ---------------
# Built once across ALL samples when config cohort_reference: true. Each
# score_sample job then maps its tracks onto this shared per-track reference
# (--normalize-method cohort-quantile), equalizing between-sample dynamic-range
# differences for the same assay. Gated by config so the default run is
# unaffected.
COHORT_NORM = bool(config.get("cohort_reference", False))
COHORT_REF  = out("cohort_quantile_reference.npz")

# Per-bin scoring divergence: "kl" (default, unbounded clamped-KL) or "jsd"
# (bounded Jensen-Shannon, per-bin total <= 1). The SAME method is used for the
# observed scores AND the permutation null so the null matches the observed
# scale; the differential null inherits it via compare_qcat on the perm qcats.
SCORE_METHOD = config.get("score_method", "kl")
# Optional explicit override for the p-value-stage score floor. If unset,
# bearing_pvalue.py picks it from --score-method (0.5 KL, 0.05 JSD).
_PV_MINSIG = config.get("pvalue_min_signal", None)
_PV_MINSIG_FLAG = ("--min-signal %s" % _PV_MINSIG) if _PV_MINSIG is not None else ""

# Opt-in adaptive (variable-width) binning. When on, a single consensus
# segmentation BED is built once and every sample + the permutation null are
# scored on it (--bins-bed). Default off -> fixed 200 bp grid, pipeline unchanged.
ADAPTIVE            = bool(config.get("adaptive_binning", False))
ADAPTIVE_SEG        = out("adaptive_segmentation.bed")
ADAPTIVE_FINE_BP    = config.get("adaptive_fine_bp", 50)
ADAPTIVE_MIN_SIGNAL = config.get("adaptive_min_signal", 0.1)
ADAPTIVE_TARGET     = config.get("adaptive_target_bins", 2000000)
_BINS_BED_FLAG      = ("--bins-bed %s" % ADAPTIVE_SEG) if ADAPTIVE else ""
_SEG_INPUT          = (ADAPTIVE_SEG if ADAPTIVE else [])

# Build the genome-wide consensus equal-coverage grid (main chromosomes only).
# Only required when ADAPTIVE (it is wired in as an input to scoring below).
rule build_adaptive_segmentation:
    input: sheet=out("samples.bearing.tsv"), blacklist=BL
    output: ADAPTIVE_SEG
    params: fine=ADAPTIVE_FINE_BP, minsig=ADAPTIVE_MIN_SIGNAL, target=ADAPTIVE_TARGET
    threads: 8
    resources: mem_mb=96000, runtime=720, cpus_per_task=8
    shell:
        "python {BIN}/build_adaptive_segmentation.py --sheet {input.sheet} "
        "--categories {CATS} --chrom-sizes {CS} --blacklist {input.blacklist} "
        "--fine-bp {params.fine} --min-signal {params.minsig} --target-bins {params.target} "
        "--main-chroms --jobs {threads} --with-stats --out {output}"

rule cohort_reference:
    input: sheet=out("samples.bearing.tsv"), blacklist=BL
    output: ref=COHORT_REF
    resources: mem_mb=64000, runtime=480
    shell:
        "python {BIN}/build_cohort_quantile_reference.py "
        "--sheet {input.sheet} --chrom-sizes {CS} --blacklist {input.blacklist} "
        "--categories {CATS} --out {output.ref}"

def _score_norm_flag(wc):
    # cohort mode overrides the within-sample normalize knob with the
    # cohort-quantile method + the reference path.
    if COHORT_NORM:
        return ("--normalize-tracks --normalize-method cohort-quantile "
                "--cohort-reference %s" % COHORT_REF)
    return P["normalize"]

# Resolved scoring settings for the provenance gate (assert_score_provenance.py).
# These MUST mirror exactly what score_sample passes to bigwig_to_qcat.py, so the
# expected signature matches the .sig each scorer stamps. _score_norm_flag takes a
# wildcards arg it does not use, so a dummy None is fine here.
NORM_FLAGS_RESOLVED = _score_norm_flag(None)
PROV_BINS_BED       = (ADAPTIVE_SEG if ADAPTIVE else "")

rule score_sample:
    input:
        blacklist=BL,
        cohort=(COHORT_REF if COHORT_NORM else []),
        seg=_SEG_INPUT
    output: qcat=out("{sample}.qcat.bgz")
    params:
        bw=lambda wc: " ".join(SAMPLE_BW[wc.sample]),
        minsig=P["min_signal"], norm=_score_norm_flag
    threads: 8
    resources: mem_mb=96000, runtime=720, cpus_per_task=8
    shell:
        "python {BIN}/bigwig_to_qcat.py --bw {params.bw} "
        "--sample-name {wildcards.sample} --out {output.qcat} "
        "--categories {CATS} --chrom-sizes {CS} --blacklist {input.blacklist} "
        "--min-signal {params.minsig} {params.norm} --score-method %s %s --jobs {threads} --signal-plots"
        % (SCORE_METHOD, _BINS_BED_FLAG)

# Aggregator: depends on every per-sample qcat; downstream rules wait on this.
rule score:
    input: qcats=[out("%s.qcat.bgz" % s) for s in SAMPLES]
    output: done=touch(out("score.done"))


# Scoring-provenance gate. Each qcat carries a sidecar <qcat>.sig stamped by
# bigwig_to_qcat.py recording the settings it ACTUALLY scored with. This rule
# recomputes the expected signature from the settings THIS config resolves to and
# fails (exit 1) on any mismatch, so the p-value layer never runs on qcats that a
# regime silently reused under different normalize/score-method/binning settings
# (the stale-qcat-reuse trap that rerun-triggers=mtime cannot see, because those
# settings are params, not file inputs). The .sig files are read from disk rather
# than declared as inputs, so this gate does not by itself force a re-score.
rule score_provenance:
    input: score=out("score.done")
    output: done=touch(out("score_provenance.done"))
    params:
        norm=NORM_FLAGS_RESOLVED, smeth=SCORE_METHOD, minsig=P["min_signal"],
        cats=CATS, binsbed=PROV_BINS_BED, samples=" ".join(SAMPLES)
    shell:
        "python {BIN}/assert_score_provenance.py --outdir {OUT} "
        "--samples {params.samples} --norm-flags '{params.norm}' "
        "--score-method {params.smeth} --min-signal {params.minsig} "
        "--categories {params.cats} --bins-bed '{params.binsbed}'"

# One-time TRUSTED backfill for trees scored before this guard existed. Writes the
# expected signature to each .sig WITHOUT re-scoring. Run manually, and ONLY on a
# tree you have independently verified is correctly scored, e.g.:
#   snakemake -s workflow/Snakefile --configfile <cfg> stamp_provenance
rule stamp_provenance:
    input: score=out("score.done")
    params:
        norm=NORM_FLAGS_RESOLVED, smeth=SCORE_METHOD, minsig=P["min_signal"],
        cats=CATS, binsbed=PROV_BINS_BED, samples=" ".join(SAMPLES)
    shell:
        "python {BIN}/assert_score_provenance.py --stamp --outdir {OUT} "
        "--samples {params.samples} --norm-flags '{params.norm}' "
        "--score-method {params.smeth} --min-signal {params.minsig} "
        "--categories {params.cats} --bins-bed '{params.binsbed}'"


# ---- Phase 2: compare (all conditions, region set) ------------------------
rule compare:
    input: sheet=out("samples.qcat.tsv"), score=out("score.done"), regions=REGIONS
    output: done=touch(out("compare.done"))
    threads: 10
    resources: mem_mb=200000, runtime=1440, cpus_per_task=10
    shell:
        "python {BIN}/compare_qcat.py --sheet {input.sheet} --out {OUT}/compare "
        "--categories {CATS} --regions-file {input.regions} --genes {GENES} "
        "--no-clip --workers {threads}"

# Supplementary Figure S1: per-track decomposition of the pairwise Q-vector JSD
# (companion to Fig 2B, the scalar q_pair_jsd_heatmap from the compare step). Uses
# the same samples.qcat.tsv, so the sample order matches Fig 2B; reads each
# sample's _cats.json (present once score.done). Panels sum to the Fig 2B scalar;
# the script asserts the reconstruction to 1e-9.
rule suppfig_s1_jsd:
    input: sheet=out("samples.qcat.tsv"), score=out("score.done")
    output:
        pdf=out("paper_figures", "suppS1_jsd_decomposition.pdf"),
        png=out("paper_figures", "suppS1_jsd_decomposition.png"),
        tsv=out("paper_figures", "suppS1_jsd_per_track.tsv")
    resources: mem_mb=8000, runtime=30
    shell:
        "python {BIN}/suppfig_s1_jsd_decomposition.py --qcat-sheet {input.sheet} "
        "--outdir {OUT}/paper_figures --prefix suppS1_jsd_decomposition"

# ---- Phase 2b: per-region raw-signal QC PNGs (pyGenomeTracks) --------------
# One PNG per sample per region (raw BigWig tracks + BEARING score track), for
# eyeballing each locus. Output: results/raw_vs_bearing/<sample>_<region>.png
rule region_qc:
    input: sheet=out("samples.qcat.tsv"), score=out("score.done"), regions=REGIONS
    output: done=touch(out("region_qc.done"))
    resources: mem_mb=32000, runtime=240
    shell:
        "python {BIN}/batch_pygenometracks.py --sheet {input.sheet} "
        "--regions-file {input.regions} --outdir {OUT}/raw_vs_bearing "
        "--dpi 200 --skip-missing-ini --run"


# ---- Phase 3: permutation nulls -- ONE JOB PER (SAMPLE, PERMUTATION) -------
# The observed null for each (sample, permutation) is independent, so they run
# as separate cluster jobs: 10 samples x N perms. Each job shifts+scores ONE
# sample for ONE permutation (about the size of a score_sample job), avoiding
# the multi-hour serial scoring that hit the wall-clock limit. A per-index
# aggregator then waits for all samples before the differential step (which
# needs every condition present) runs for that permutation.
rule perm_sample_one:
    input:
        sheet=out("samples.bearing.tsv"), score=out("score.done"), blacklist=BL,
        cohort=(COHORT_REF if COHORT_NORM else []),
        seg=_SEG_INPUT
    output: out("perm", "perm{idx}", "{sample}", "{sample}_perm{idx}.qcat.bgz")
    params:
        n=P["n_perms"], shift=P["min_shift"], seed=P["seed"], minsig=P["min_signal"],
        norm=_score_norm_flag
    threads: 8
    resources: mem_mb=96000, runtime=720, cpus_per_task=8
    shell:
        "python {BIN}/generate_perm_nulls.py --sheet {input.sheet} --out-dir {OUT}/perm "
        "--chrom-sizes {CS} --n-perms {params.n} --perm-index {wildcards.idx} "
        "--only-sample {wildcards.sample} "
        "--blacklist {input.blacklist} --min-signal {params.minsig} "
        "--min-shift {params.shift} --seed {params.seed} "
        "{params.norm} --score-method %s %s "
        "--shift-workers {threads} --jobs {threads} && "
        "python {BIN}/assert_qcat_nonempty.py {output} "
        "--min-signal {params.minsig} --min-bins 1000" % (SCORE_METHOD, _BINS_BED_FLAG)

# Per-index aggregator: all samples' observed nulls for this permutation exist.
rule perm_null_one:
    input: [out("perm", "perm{idx}", s, "%s_perm{idx}.qcat.bgz" % s) for s in SAMPLES]
    output: touch(out("perm", "perm{idx}.obs.done"))

rule perm_diff_one:
    input: obs=out("perm", "perm{idx}.obs.done"),
           sheet=out("samples.bearing.tsv"), blacklist=BL
    output: touch(out("perm", "perm{idx}.diff.done"))
    params: n=P["n_perms"]
    threads: 8
    resources: mem_mb=120000, runtime=720, cpus_per_task=8
    shell:
        "python {BIN}/generate_perm_nulls.py --sheet {input.sheet} --diff-sheet {input.sheet} "
        "--chrom-sizes {CS} --n-perms {params.n} --perm-index {wildcards.idx} "
        "--out-dir {OUT}/perm --blacklist {input.blacklist} --jobs {threads}"

# Aggregators: wait for all permutation rounds.
rule perm_nulls:
    input: [out("perm", "perm%d.obs.done" % i) for i in PERM_INDICES]
    output: touch(out("perm.done"))

rule perm_nulls_diff:
    input: [out("perm", "perm%d.diff.done" % i) for i in PERM_INDICES]
    output: touch(out("perm_diff.done"))


# ---- Phase 4: differential p-values --------------------------------------
# Per-comparison so the 10 comparisons run concurrently (was one ~37h serial
# job). Each job loads one comparison's nulls and is independently restart-safe
# via the resume guard in run_pvalue_one.sh. The aggregator just gates on all
# per-comparison outputs.
rule pvalue_diff_one:
    input: compare=out("compare.done"), perm_diff=out("perm_diff.done"),
           prov=out("score_provenance.done")
    output: stats=out("pvalue", "diff_{comp}.stats.tsv")
    wildcard_constraints: comp=ALL_PAIRWISE_RE
    params: n=P["n_perms"]
    threads: 4
    resources: mem_mb=256000, runtime=600, cpus_per_task=4
    shell:
        "export OMP_NUM_THREADS=1 MKL_NUM_THREADS=1 OPENBLAS_NUM_THREADS=1; "
        "bash {BIN}/slurm/run_pvalue_one.sh {OUT}/compare {wildcards.comp} {params.n} "
        "{OUT}/perm/perm {OUT}/pvalue %s %s"
        % (SCORE_METHOD, ("'%s'" % _PV_MINSIG) if _PV_MINSIG is not None else "''")

rule pvalue_diff:
    input: expand(out("pvalue", "diff_{comp}.stats.tsv"), comp=ALL_PAIRWISE)
    output: done=touch(out("pvalue.done"))

# Per-sample (non-diff) p-values: run bearing_pvalue.py for each sample against
# its OWN permutation nulls (perm/perm{idx}/{sample}/{sample}_perm{idx}.qcat.bgz,
# built by perm_sample_one). Produces pvalue/<sample>.stats.tsv and
# <sample>.neglog10p.bw so the figure qcat-A/qcat-B rows can carry per-sample
# significance markers (distinct from the differential diff_<cmp> p-values).
rule pvalue_sample:
    input:
        qcat=out("{sample}.qcat.bgz"),
        perm=out("perm.done"),
        prov=out("score_provenance.done"),
        # The per-sample permutation nulls are real INPUTS, not just params, so
        # Snakemake regenerates any missing/deleted/failed-assertion perm qcat
        # automatically instead of running into the scorer's pre-load gate. (They
        # were previously params-only, which is why deleting a bad perm did NOT
        # trigger a rebuild.)
        nulls=lambda wc: [
            out("perm", "perm%d" % i, wc.sample, "%s_perm%d.qcat.bgz" % (wc.sample, i))
            for i in PERM_INDICES]
    output: out("pvalue", "{sample}.neglog10p.bw")
    params:
        prefix=lambda wc: out("pvalue", wc.sample),
        nulls=lambda wc: " ".join(
            out("perm", "perm%d" % i, wc.sample, "%s_perm%d.qcat.bgz" % (wc.sample, i))
            for i in PERM_INDICES)
    threads: 2
    resources: mem_mb=164000, runtime=720, cpus_per_task=2
    shell:
        "export OMP_NUM_THREADS=1 MKL_NUM_THREADS=1 OPENBLAS_NUM_THREADS=1; "
        "python {BIN}/bearing_pvalue.py --qcat {input.qcat} "
        "--null-qcat {params.nulls} --out-prefix {params.prefix} --fdr 0.05 "
        "--expect-n-perms %d "
        "--score-method %s %s" % (len(PERM_INDICES), SCORE_METHOD, _PV_MINSIG_FLAG)

rule pvalue_samples:
    input: [out("pvalue", "%s.neglog10p.bw" % s) for s in SAMPLES]
    output: touch(out("pvalue_samples.done"))


# ---- Phase 5: regional enrichment (per locus, joint 20-test BH) -----------
# Per-comparison rule emits RAW p_combined (--bh-by none); the consolidate rule
# applies the joint BH across the whole region x comparison family per locus.
rule regional_enrichment:
    input: pvalue=out("pvalue.done")
    output: out("regional", "enrich_{cmp}_{locus}.tsv")
    wildcard_constraints: cmp=REGIONAL_CMP_RE, locus=REGIONAL_LOCUS_RE
    params:
        bed=lambda wc: os.path.join(BIN, REGIONAL_LOCI[wc.locus]["bed"]),
        window=lambda wc: REGIONAL_LOCI[wc.locus]["window"],
        pthresh=REGIONAL_PTHRESH,
    resources: mem_mb=100000, runtime=1440
    shell:
        "python {BIN}/regional_enrichment.py batch "
        "--diff-table {OUT}/pvalue/diff_{wildcards.cmp}.stats.tsv "
        "--regions {params.bed} --locus {params.window} "
        "--p-thresh {params.pthresh} --bh-by none --out {output}"

rule regional_consolidate:
    input: lambda wc: expand(out("regional", "enrich_{cmp}_%s.tsv" % wc.locus), cmp=COMPARISONS)
    output: tsv=out("regional", "consolidated_enrichment_{locus}.tsv"),
            pdf=out("regional", "panel_E_heatmap_{locus}.pdf")
    wildcard_constraints: locus=REGIONAL_LOCUS_RE
    shell:
        "python {BIN}/consolidate_regional_enrichment.py --tsvs {input} "
        "--joint-bh "
        "--out {output.tsv} --heatmap-out {output.pdf} "
        "--comparisons " + " ".join(COMPARISONS)

# Per-CBE point query: CBEs are ~18 bp (sub-bin), so a regional-enrichment test
# over them is structurally empty (zero bins fall within an 18 bp region). The
# honest query maps each CBE to its overlapping 200 bp bin and reports that
# bin's BES / p-value / FDR / per-track decomposition, across all comparisons.
rule cbe_point_query:
    input: pvalue=out("pvalue.done")
    output: tsv=out("regional", "cbe_point_query.tsv"),
            summary=out("regional", "cbe_significant_summary.tsv")
    resources: mem_mb=32000, runtime=120
    params:
        diffs=lambda wc: " ".join(
            "%s/pvalue/diff_%s.stats.tsv" % (OUT, c) for c in COMPARISONS)
    shell:
        "python {BIN}/cbe_point_query.py --diffs {params.diffs} "
        "--cbe-bed {BIN}/annotations/cbe_mm10.bed "
        "--categories {OUT}/DN_rep1_cats.json --out {output.tsv} "
        "--summary-out {output.summary}"

# Per-track differential changes (signed kl_<track> + p-values) at known CTCF
# elements (point: containing bin) and AgR genes (region: aggregated over the
